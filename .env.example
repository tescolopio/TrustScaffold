# Browser-safe values. These are allowed in the client bundle.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secrets. Never expose these in client components or NEXT_PUBLIC_* env vars.
SUPABASE_SERVICE_ROLE_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
AZURE_DEVOPS_PAT=

# Upstash Redis — required for per-org rate limiting on /api/v1/evidence/ingest and /api/webhooks/github.
# If unset, rate limiting is silently skipped (safe for local dev, not for production).
# Get credentials at https://console.upstash.com → Create Database → REST API.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
